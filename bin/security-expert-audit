#!/usr/bin/env bash
set -u

printf '\n== linux-admin security-expert read-only audit ==\n'
printf 'Generated: %s\n' "$(date -Is 2>/dev/null || date)"

section() {
  printf '\n## %s\n' "$1"
}

run() {
  printf '\n$ %s\n' "$*"
  "$@" 2>/dev/null || true
}

section "System"
run uname -a
run cat /etc/os-release

section "Network exposure"
run ss -tulpen
run ip -brief addr
run ip route
run ip -6 route

section "SSH policy"
run sshd -T
run systemctl status ssh --no-pager
run systemctl status sshd --no-pager
run grep -R --line-number -E 'PasswordAuthentication|PermitRootLogin|PubkeyAuthentication|MaxAuthTries|AllowUsers|AllowGroups|KbdInteractiveAuthentication|ChallengeResponseAuthentication|LoginGraceTime' /etc/ssh/sshd_config /etc/ssh/sshd_config.d

section "Firewall state"
run firewall-cmd --state
run firewall-cmd --list-all
run nft list ruleset
run iptables -S
run ip6tables -S

section "Systemd services"
run systemctl --failed --no-pager
run systemctl list-units --type=service --state=running --no-pager

section "Kernel/sysctl security keys"
for key in \
  kernel.dmesg_restrict \
  kernel.kptr_restrict \
  kernel.yama.ptrace_scope \
  kernel.perf_event_paranoid \
  kernel.unprivileged_bpf_disabled \
  kernel.sysrq \
  fs.protected_hardlinks \
  fs.protected_symlinks \
  fs.protected_fifos \
  fs.protected_regular \
  fs.suid_dumpable \
  vm.mmap_min_addr \
  net.ipv4.tcp_syncookies \
  net.ipv4.icmp_echo_ignore_broadcasts \
  net.ipv4.icmp_ignore_bogus_error_responses \
  net.ipv4.conf.all.accept_redirects \
  net.ipv4.conf.default.accept_redirects \
  net.ipv4.conf.all.accept_source_route \
  net.ipv4.conf.default.accept_source_route \
  net.ipv4.conf.all.rp_filter \
  net.ipv4.conf.default.rp_filter \
  net.ipv4.conf.all.log_martians \
  net.ipv4.conf.default.log_martians \
  net.ipv6.conf.all.accept_redirects \
  net.ipv6.conf.default.accept_redirects \
  net.ipv6.conf.all.accept_source_route \
  net.ipv6.conf.default.accept_source_route; do
  sysctl "$key" 2>/dev/null || true
done

section "Limits"
run cat /proc/self/limits
run cat /proc/sys/fs/file-nr
run cat /proc/sys/fs/file-max
run cat /proc/sys/fs/nr_open
run cat /proc/sys/kernel/threads-max
run cat /proc/sys/kernel/pid_max
run grep -R --line-number -E '^[^#].*(nofile|nproc|memlock|as|rss|stack|core|locks)' /etc/security/limits.conf /etc/security/limits.d

section "Users and privilege boundaries"
run id
run getent passwd
run getent group sudo
run getent group wheel
run find / -xdev -perm -4000 -type f -print
run getcap -r /

section "Logging and detection"
run journalctl -p warning..alert -b --no-pager -n 200
run auditctl -s
run systemctl status auditd --no-pager
run systemctl status fail2ban --no-pager

section "Package posture"
run apt list --upgradable
run dnf check-update
run yum check-update
run zypper list-updates

section "Backup hints"
run findmnt
run systemctl list-timers --all --no-pager
run crontab -l
run ls -la /backup /backups /mnt /srv

printf '\n== end read-only audit ==\n'
